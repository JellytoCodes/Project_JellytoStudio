    <Block id="3" name="Priming1"
        renderType="Model"
        modelName="Priming_01"
	modelScale= "0.01"
        collider="Unit"
        ownChannel="Priming"
        pickable="Priming|Floor|Character"
        faces="Top|Side"/>

    <Block id="4" name="Priming2"
           renderType="Model"
