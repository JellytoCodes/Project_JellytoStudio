<?xml version="1.0" encoding="utf-8"?>
<!--
    BlockDefs.xml — 하이브리드 인스턴싱 파이프라인 블록 정의
    
    renderType="Mesh"  : 엔진 기본 Cube Mesh + 팔레트 텍스처에서 단색 픽셀 샘플링
                         paletteU/V = 팔레트 텍스처 내 목표 색상 픽셀의 UV 좌표
                         (uvScale=0 이므로 큐브 전면이 동일 색상으로 칠해짐)
                         
    renderType="Model" : FBX 모델 로드 + 팔레트 UV가 이미 베이크된 상태
                         UV 변환 없음 (uScale=1, vScale=1 passthrough)
-->
<BlockDefs paletteTex="../Resources/Textures/MapModel/Main_texture.png">

    <!-- ── Case B: FBX 모델 (팔레트 UV 베이크) ─────────────────────────── -->
    <Block id="0" name="Mushroom1"
           renderType="Model"
           model="../Resources/Models/MapModel/Mushroom1.fbx"
           modelScale="1.0"
           collider="Small"
           ownChannel="Mushroom"
           pickable="Priming"
           faces="Top"/>

    <Block id="1" name="Mushroom2"
           renderType="Model"
           model="../Resources/Models/MapModel/Mushroom2.fbx"
           modelScale="1.0"
           collider="Small"
           ownChannel="Mushroom"
           pickable="Priming"
           faces="Top"/>

    <Block id="2" name="Mushroom3"
           renderType="Model"
           model="../Resources/Models/MapModel/Mushroom3.fbx"
           modelScale="1.0"
           collider="Small"
           ownChannel="Mushroom"
           pickable="Priming"
           faces="Top"/>

    <!-- ── Case A: Cube Mesh (팔레트 단색 픽셀 샘플) ───────────────────── -->
    <!--   paletteU/V: 텍스처 픽셀 좌표 = (픽셀X + 0.5) / 텍스처폭         -->
    <!--   실제 팔레트 좌표로 교체 필요                                     -->
    <Block id="3" name="Priming1"
           renderType="Mesh"
           paletteU="0.1406" paletteV="0.1406"
           collider="Unit"
           ownChannel="Priming"
           pickable="Priming|Floor|Character"
           faces="Top|Side"/>

    <Block id="4" name="Priming2"
           renderType="Mesh"
           paletteU="0.2656" paletteV="0.1406"
           collider="Unit"
           ownChannel="Priming"
           pickable="Priming|Floor|Character"
           faces="Top|Side"/>

    <Block id="5" name="Priming3"
           renderType="Mesh"
           paletteU="0.3906" paletteV="0.1406"
           collider="Unit"
           ownChannel="Priming"
           pickable="Priming|Floor|Character"
           faces="Top|Side"/>

    <Block id="6" name="Bridge"
           renderType="Mesh"
           paletteU="0.5156" paletteV="0.1406"
           collider="Wide"
           ownChannel="Priming"
           pickable="Priming|Floor|Character"
           faces="Top|Side"/>

    <Block id="7" name="Eraser"
           renderType="Mesh"
           paletteU="0.0f" paletteV="0.0f"
           collider="Unit"
           ownChannel="Default"
           pickable="All"
           faces="All"/>

</BlockDefs>
