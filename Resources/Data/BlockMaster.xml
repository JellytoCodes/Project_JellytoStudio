               renderType="Model" modelName="Mushroom_03" modelScale="0.01"
               collider="Small"   ownChannel="Mushroom"
               pickable="Priming" faces="Top"/>

        <!-- ── Priming 계열 (FBX, Priming 채널) ───────────────────────── -->
        <Block id="3"
