               isEraser="false"
               renderType="Model" modelName="Mushroom_01" modelScale="0.01"
               collider="Small"   ownChannel="Mushroom"
               pickable="Priming" faces="Top"/>

        <Block id="1"
               key="Mushroom2"    label="버섯2"    paletteLabel="Mushroom2"
               colorR="0.22"      colorG="0.32"    colorB="0.20"  colorA="0.90"
               isEraser="false"
               renderType="Model" modelName="Mushroom_02" modelScale="0.01"
               collider="Small"   ownChannel="Mushroom"
               pickable="Priming" faces="Top"/>

        <Block id="2"
               key="Mushroom3"    label="버섯3"    paletteLabel="Mushroom3"
