<?xml version="1.0" encoding="UTF-8"?>
<!--
    BlockMaster.xml
    BlockData.xml + BlockDefs.xml 통합 데이터 파일.

    <Block> 속성 설명:
      id           : SlotType enum 정수값 (0부터 순서대로)
      key          : 코드 내 참조키 (PhaseSequence slotKey 와 일치해야 함)
      label        : 인게임 표시 이름
      paletteLabel : 팔레트 UI 슬롯 표시 이름
      colorR/G/B/A : 팔레트 슬롯 배경색

      renderType   : "Mesh" | "Model"
        Mesh  → 엔진 기본 Cube + 팔레트 단색 샘플링 (paletteU/V 좌표 지정)
        Model → FBX 모델 로드 (modelName 으로 ReadModel/ReadMaterial 호출)
      modelName    : FBX 파일명 (확장자·경로 제외, SetModelPath 기준 상대명)
      modelScale   : 모델 스케일 보정값 (대부분 0.01)
      paletteU/V   : Mesh 타입 전용 — 팔레트 텍스처 내 목표 픽셀 UV
                     공식: (픽셀X + 0.5) / 텍스처폭

      collider     : "Small" | "Unit" | "Tall" | "Wide"
      ownChannel   : "Default" | "Character" | "Priming" | "Mushroom" | "Floor"
      pickable     : 레이캐스팅 채널 마스크 ("Priming|Floor|Character" 형식, "All" 가능)
      faces        : 블록 위에 배치 가능한 면 ("Top|Side|Bot" 형식, "All" 가능)
-->
<BlockMaster paletteTex="../Resources/Textures/MapModel/Main_texture.png">

    <Blocks>

        <!-- ── Mushroom 계열 (FBX, Mushroom 채널) ─────────────────────── -->
        <Block id="0"
